# AI FDE Collection Assistant - Environment Variables
# Copy this file to .env and fill in your values

# LLM Provider: free_cloud | local | hybrid | premium
LLM_PROVIDER=free_cloud

# Groq free tier (https://console.groq.com - no credit card needed)
GROQ_API_KEY=gsk_your_key_here

# Ollama (local mode only)
OLLAMA_BASE_URL=http://localhost:11434

# Anthropic (premium/hybrid only - not needed for PoC)
ANTHROPIC_API_KEY=

# Database
DATABASE_URL=sqlite:///data/collection_assistant.db

# API
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit
STREAMLIT_API_URL=http://localhost:8000
